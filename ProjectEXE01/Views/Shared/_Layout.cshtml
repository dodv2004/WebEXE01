<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - AntiScam</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --primary-color: #dc3545;
            --secondary-color: #ffc107;
            --dark-bg: #0f0f1e;
            --card-bg: #1a1a2e;
            --text-light: #e0e0e0;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8f9fa;
        }

        /* Navbar Styling */
        .navbar {
            background: linear-gradient(135deg, var(--dark-bg) 0%, #1a1a2e 100%) !important;
            box-shadow: 0 2px 15px rgba(0,0,0,0.1);
            padding: 1rem 0;
        }

        .navbar-brand {
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: 1px;
            transition: transform 0.3s ease;
        }

            .navbar-brand:hover {
                transform: translateY(-2px);
            }

        .nav-link {
            font-weight: 500;
            margin: 0 0.5rem;
            transition: all 0.3s ease;
            position: relative;
        }

            .nav-link::after {
                content: '';
                position: absolute;
                bottom: -5px;
                left: 50%;
                width: 0;
                height: 2px;
                background: var(--secondary-color);
                transition: all 0.3s ease;
                transform: translateX(-50%);
            }

            .nav-link:hover::after {
                width: 80%;
            }

        .btn-report-header {
            background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
            border: none;
            box-shadow: 0 4px 15px rgba(220, 53, 69, 0.4);
            transition: all 0.3s ease;
        }

            .btn-report-header:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(220, 53, 69, 0.6);
            }

        /* Hero Section */
        .hero-section {
            background: linear-gradient(135deg, #0f0f1e 0%, #1a1a2e 50%, #16213e 100%);
            position: relative;
            overflow: hidden;
            padding: 5rem 0 !important;
        }

            .hero-section::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: radial-gradient(circle at 20% 50%, rgba(220, 53, 69, 0.1) 0%, transparent 50%), radial-gradient(circle at 80% 80%, rgba(255, 193, 7, 0.1) 0%, transparent 50%);
                animation: pulse 8s ease-in-out infinite;
            }

        @@keyframes pulse {
            0%, 100% {
                opacity: 0.5;
            }

            50% {
                opacity: 1;
            }
        }

        .hero-section h1 {
            font-size: 3.5rem;
            font-weight: 800;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            animation: fadeInDown 1s ease;
            position: relative;
            z-index: 1;
        }

        @@keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Search Form */
        .search-form {
            max-width: 700px;
            position: relative;
            z-index: 1;
            animation: fadeInUp 1s ease 0.3s both;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .search-form .input-group {
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            border-radius: 50px;
            overflow: hidden;
        }

        .search-form input {
            padding: 1.2rem 1.5rem;
            font-size: 1.1rem;
            border-radius: 50px 0 0 50px !important;
        }

        .search-form button {
            padding: 1.2rem 2.5rem;
            background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
            border: none;
            font-size: 1.1rem;
            transition: all 0.3s ease;
        }

            .search-form button:hover {
                background: linear-gradient(135deg, #c82333 0%, #bd2130 100%);
                transform: scale(1.05);
            }

        /* Alert Messages */
        .alert {
            border-radius: 15px;
            border: none;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
            animation: slideInDown 0.5s ease;
        }

        @@keyframes slideInDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Feature Cards */
        .feature-card {
            transition: all 0.3s ease;
            border-radius: 15px;
            overflow: hidden;
            height: 100%;
        }

            .feature-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 15px 40px rgba(0,0,0,0.15) !important;
            }

            .feature-card .card-body {
                padding: 2rem;
            }

            .feature-card h5 {
                font-size: 1.3rem;
                margin-bottom: 1rem;
            }

            .feature-card .btn {
                margin-top: 1rem;
                transition: all 0.3s ease;
            }

                .feature-card .btn:hover {
                    transform: translateX(5px);
                }

        /* Report Button */
        .btn-report-main {
            background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
            border: none;
            padding: 1rem 3rem;
            font-size: 1.2rem;
            border-radius: 50px;
            box-shadow: 0 8px 25px rgba(255, 193, 7, 0.4);
            transition: all 0.3s ease;
            animation: pulse-glow 2s ease-in-out infinite;
        }

        @@keyframes pulse-glow {
            0%, 100% {
                box-shadow: 0 8px 25px rgba(255, 193, 7, 0.4);
            }

            50% {
                box-shadow: 0 8px 35px rgba(255, 193, 7, 0.6);
            }
        }

        .btn-report-main:hover {
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 12px 35px rgba(255, 193, 7, 0.6);
            background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
        }

        /* Media Section */
        .media-section {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            position: relative;
        }

            .media-section::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: url('data:image/svg+xml,<svg width="100" height="100" xmlns="http://www.w3.org/2000/svg"><rect width="100" height="100" fill="none"/><circle cx="50" cy="50" r="2" fill="rgba(255,255,255,0.05)"/></svg>');
                opacity: 0.3;
            }

        /* Footer */
        footer {
            background: linear-gradient(135deg, var(--dark-bg) 0%, #1a1a2e 100%);
            padding: 2rem 0;
            box-shadow: 0 -2px 15px rgba(0,0,0,0.1);
        }

        /* Icon Styling */
        .icon-emoji {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            display: inline-block;
            animation: bounce 2s ease-in-out infinite;
        }

        @@keyframes bounce {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-10px);
            }
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .hero-section h1 {
                font-size: 2rem;
            }

            .search-form input {
                padding: 1rem;
                font-size: 1rem;
            }

            .search-form button {
                padding: 1rem 1.5rem;
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">
                <a class="navbar-brand text-warning" href="@Url.Action("Index", "Home")">
                    <i class="fas fa-shield-alt me-2"></i>AntiScam
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @if (Context.Session.GetString("UserEmail") != null )
                        {
                            <li class="nav-item me-2">
                                <a class="nav-link btn btn-outline-warning text-warning fw-bold px-3 rounded-pill shadow-sm"
                                   asp-controller="Account" asp-action="UpgradeVip">
                                    <i class="fas fa-crown me-1"></i> Nâng cấp VIP
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("News", "Home")">
                                <i class="fas fa-newspaper me-1"></i>Tin tức
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Resources", "Home")">
                                <i class="fas fa-book me-1"></i>Tài nguyên
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Ranking", "Home")">
                                <i class="fas fa-trophy me-1"></i>Bảng xếp hạng
                            </a>
                        </li>
                        
                    </ul>
                    <div class="d-flex align-items-center">
                        @if (Context.Session.GetString("UserEmail") != null)
                        {
                            <div class="dropdown me-3">
                                <a class="nav-link dropdown-toggle text-light fw-bold" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle me-1 text-warning"></i> @Context.Session.GetString("UserEmail")
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="background: #1a1a2e;">
                                    <li><a class="dropdown-item text-light" href="/Account/Profile"><i class="fas fa-id-card me-2"></i>Hồ sơ</a></li>
                                    <li><hr class="dropdown-divider bg-secondary"></li>
                                    <li><a class="dropdown-item text-danger fw-bold" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <ul class="navbar-nav me-3">
                                <li class="nav-item">
                                    <a class="nav-link fw-bold" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                                </li>
                            </ul>
                        }

                        <a class="btn btn-danger btn-lg fw-bold btn-report-header rounded-pill px-4" href="/Home/SelectAction">
                            <i class="fas fa-exclamation-triangle me-2"></i>Báo cáo
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main>
        @RenderBody()
    </main>
    <footer class="text-center text-white mt-auto">
        <div class="container">
            <p class="mb-2">
                <i class="fas fa-shield-alt me-2"></i>
                <strong>AntiScam Việt Nam</strong> - Cùng nhau chống lừa đảo trực tuyến
            </p>
            <p class="mb-0 opacity-75">© 2025 AntiScam. Bảo vệ cộng đồng, lan tỏa cảnh giác.</p>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>