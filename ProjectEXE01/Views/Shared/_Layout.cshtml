<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - AntiScam</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold text-warning" href="@Url.Action("Index", "Home")">AntiScam</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("News", "Home")">Tin tức</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Resources", "Home")">Tài nguyên</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Ranking", "Home")">Bảng xếp hạng</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Media", "Home")">Truyền thông</a></li>
                    </ul>

                    <div class="d-flex">
                        <a class="btn btn-danger btn-lg fw-bold" href="/Home/SelectAction">🚨 Báo cáo</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="bg-dark text-center text-white py-3 mt-auto">
        <p class="mb-0">© 2025 AntiScam Việt Nam</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false) <!-- Thêm dòng này để render section Scripts -->
</body>
</html>