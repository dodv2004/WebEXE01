@{
    ViewBag.Title = "Nâng cấp VIP - AntiScam";
}

<section class="py-5" style="background: var(--dark-bg); min-height: 90vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 text-center">
                <div class="card border-0 shadow-lg p-4" style="background: var(--card-bg); border-radius: 20px;">
                    <h2 class="fw-bold text-warning mb-3"><i class="fas fa-crown me-2"></i>Trở thành Hiệp sĩ VIP</h2>
                    <p class="text-white-50">Mở khóa tính năng tra cứu không giới hạn chỉ với <strong>89.000đ</strong></p>

                    @* KHU VỰC MÃ QR CỦA BẠN *@
                    <div class="bg-white p-3 d-inline-block rounded-4 shadow-sm my-4">
                        <img src="~/images/qr-payment.png" alt="Thanh toán QR" style="width: 250px; height: 250px; object-fit: contain;" />
                    </div>

                    <div class="alert alert-info border-0 small text-start mb-4">
                        <i class="fas fa-info-circle me-2"></i><strong>Hướng dẫn:</strong>
                        Quét mã trên để thanh toán. Trong phần nội dung chuyển khoản, hãy ghi đúng:
                        <span class="text-danger fw-bold">VIP [Email của bạn]</span>
                    </div>
                    <form id="upgradeForm" asp-action="ProcessUpgrade" method="post">
                        <button type="submit" id="btnSubmit" class="btn btn-warning w-100 fw-bold py-3 rounded-pill">
                            Tôi đã chuyển khoản thành công
                        </button>
                    </form>

                    <script>
                        document.getElementById('upgradeForm').onsubmit = function() {
                            var btn = document.getElementById('btnSubmit');
                            // Vô hiệu hóa nút và đổi chữ để người dùng biết hệ thống đang chạy
                            btn.disabled = true;
                            btn.classList.replace('btn-warning', 'btn-secondary');
                            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Đang xử lý...';
                            return true;
                        };
                    </script>

                    <a href="/" class="d-block mt-3 text-white-50 text-decoration-none small">Quay lại trang chủ</a>
                </div>
            </div>
        </div>
    </div>
</section>