@{
    ViewBag.Title = "Nâng cấp VIP - AntiScam";
}

<section class="py-5" style="background: var(--dark-bg); min-height: 90vh;">
    <div class="container">
        <div class="text-center mb-5 animate__animated animate__fadeInDown">
            <h2 class="display-5 fw-bold text-light">Nâng cấp trải nghiệm <span class="text-warning">VIP</span></h2>
            <p class="text-white-50">Đồng hành cùng cộng đồng, bảo vệ bản thân không giới hạn.</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card border-0 shadow-lg text-light p-4"
                     style="background: var(--card-bg); border-radius: 30px; border: 2px solid #ffc107 !important;">
                    <div class="card-body text-center">
                        <div class="badge bg-danger mb-3 px-3 py-2 rounded-pill shadow">PHỔ BIẾN NHẤT</div>
                        <h3 class="fw-bold mb-4">Gói Bảo Vệ Tháng</h3>

                        <div class="price-tag mb-4">
                            <span class="display-3 fw-bold text-warning">89k</span>
                            <span class="text-white-50">/ tháng</span>
                        </div>

                        <ul class="list-unstyled text-start mb-5 opacity-90">
                            <li class="mb-3"><i class="fas fa-check-circle text-success me-2"></i> Tra cứu lừa đảo **không giới hạn**</li>
                            <li class="mb-3"><i class="fas fa-check-circle text-success me-2"></i> Huy hiệu **VIP Gold** trên hồ sơ</li>
                            <li class="mb-3"><i class="fas fa-check-circle text-success me-2"></i> Ưu tiên xử lý báo cáo từ bạn</li>
                            <li class="mb-3"><i class="fas fa-check-circle text-success me-2"></i> Không quảng cáo & tính năng mới sớm nhất</li>
                        </ul>

                        <form asp-action="ProcessUpgrade" method="post">
                            <button type="submit" class="btn btn-warning btn-lg w-100 fw-bold py-3 rounded-pill shadow-lg text-dark">
                                <i class="fas fa-rocket me-2"></i> Nâng cấp ngay bây giờ
                            </button>
                        </form>

                        <p class="mt-3 text-white-50 small">Thanh toán an toàn qua MoMo hoặc Chuyển khoản ngân hàng</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>