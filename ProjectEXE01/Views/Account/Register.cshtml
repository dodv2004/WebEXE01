@model DAL.Models.RegisterViewModel
@{
    ViewBag.Title = "Đăng ký thành viên - AntiScam";
}

<section class="py-5 d-flex align-items-center" style="background: var(--dark-bg); min-height: 85vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card border-0 shadow-lg p-4" style="background: var(--card-bg); border-radius: 20px;">
                    <div class="text-center mb-4">
                        <div class="display-4 text-warning mb-2"><i class="fas fa-user-plus"></i></div>
                        <h3 class="fw-bold text-light">Tạo tài khoản</h3>
                        <p class="text-muted small">Tham gia cộng đồng cùng chống lừa đảo</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger border-0 small py-2 mb-3">@ViewBag.Error</div>
                    }

                    <form asp-action="Register" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label text-light opacity-75 small">Email xác thực</label>
                            <input asp-for="Email" class="form-control bg-dark text-light border-secondary shadow-none" placeholder="email@gmail.com" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-light opacity-75 small">Mật khẩu</label>
                            <input asp-for="Password" type="password" class="form-control bg-dark text-light border-secondary shadow-none" placeholder="Ít nhất 6 ký tự" required />
                        </div>
                        <div class="mb-4">
                            <label class="form-label text-light opacity-75 small">Xác nhận mật khẩu</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control bg-dark text-light border-secondary shadow-none" placeholder="Nhập lại mật khẩu" required />
                        </div>
                        <button type="submit" class="btn btn-warning w-100 fw-bold py-2 mb-3 rounded-pill text-dark">
                            Gửi mã xác thực OTP
                        </button>
                    </form>

                    <div class="text-center">
                        <p class="text-muted small mb-0">Đã có tài khoản? <a asp-action="Login" class="text-danger fw-bold text-decoration-none">Đăng nhập</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>