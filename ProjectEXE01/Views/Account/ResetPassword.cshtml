@{
    ViewBag.Title = "Đặt lại mật khẩu - AntiScam";
}

<section class="py-5" style="background: var(--dark-bg); min-height: 90vh;">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card border-0 shadow-lg text-light" style="background: var(--card-bg); border-radius: 20px;">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <div class="display-4 text-warning mb-2"><i class="fas fa-key"></i></div>
                            <h3 class="fw-bold">Mật khẩu mới</h3>
                            <p class="text-white-50">Nhập mật khẩu mới cho tài khoản @ViewBag.Email</p>
                        </div>

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger border-0 small">@ViewBag.Error</div>
                        }

                        <form asp-action="ResetPassword" method="post">
                            <input type="hidden" name="email" value="@ViewBag.Email" />
                            <input type="hidden" name="otp" value="@ViewBag.OTP" />

                            <div class="mb-3">
                                <label class="form-label small opacity-75">Mật khẩu mới</label>
                                <input type="password" name="newPassword" class="form-control bg-dark border-secondary text-white py-3 rounded-pill" required minlength="6">
                            </div>

                            <div class="mb-4">
                                <label class="form-label small opacity-75">Xác nhận mật khẩu</label>
                                <input type="password" name="confirmPassword" class="form-control bg-dark border-secondary text-white py-3 rounded-pill" required>
                            </div>

                            <button type="submit" class="btn btn-warning w-100 fw-bold py-3 rounded-pill shadow">
                                <i class="fas fa-check-circle me-2"></i>Cập nhật mật khẩu
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>