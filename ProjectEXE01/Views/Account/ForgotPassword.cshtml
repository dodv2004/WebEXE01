@{
    ViewBag.Title = "Quên mật khẩu - AntiScam";
}

<section class="py-5 d-flex align-items-center" style="background: var(--dark-bg); min-height: 80vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card border-0 shadow-lg p-4" style="background: var(--card-bg); border-radius: 20px;">
                    <div class="text-center mb-4">
                        <div class="display-4 text-warning mb-2"><i class="fas fa-key"></i></div>
                        <h3 class="fw-bold text-light">Quên mật khẩu?</h3>
                        <p class="text-muted small">Nhập email của bạn để nhận mã đặt lại mật khẩu</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger border-0 small py-2 mb-3">
                            <i class="fas fa-exclamation-triangle me-2"></i>@ViewBag.Error
                        </div>
                    }

                    <form asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-4">
                            <label class="form-label text-light opacity-75 small">Email đã đăng ký</label>
                            <input type="email" name="email" class="form-control bg-dark text-light border-secondary shadow-none"
                                   placeholder="name@example.com" required />
                        </div>

                        <button type="submit" class="btn btn-warning w-100 fw-bold py-2 mb-3 rounded-pill text-dark">
                            Gửi mã xác thực OTP
                        </button>
                    </form>

                    <div class="text-center">
                        <a asp-action="Login" class="text-muted text-decoration-none small">
                            <i class="fas fa-arrow-left me-1"></i> Quay lại Đăng nhập
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>