@model DAL.Models.ReportViewModel
@{
    ViewData["Title"] = "Báo cáo lừa đảo";
}

<div class="container py-5">
    <h2 class="text-center mb-4 text-danger fw-bold">Gửi báo cáo chống lừa đảo</h2>

    <div class="card shadow p-4">
        @if (ViewBag.Success != null)
        {
            <div class="alert alert-success">
                @ViewBag.Success
            </div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Error
            </div>
        }

        <form method="post" action="@Url.Action("SubmitReport", "Home")" class="form-horizontal">
            @Html.AntiForgeryToken()

            <div class="form-group mb-3">
                <label asp-for="Query" class="control-label col-md-2"></label>
                <div class="col-md-10">
                    @Html.TextBoxFor(m => m.Query, new { @class = "form-control", placeholder = "Nhập số điện thoại, STK hoặc link" })
                    @Html.ValidationMessageFor(m => m.Query, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Type" class="control-label col-md-2"></label>
                <div class="col-md-10">
                    @Html.DropDownListFor(m => m.Type, new SelectList(new[]
                    {
                        new { Value = "phone", Text = "Số điện thoại" },
                                        new { Value = "bank", Text = "Tài khoản ngân hàng" },
                                        new { Value = "link", Text = "Link" }
                                        }, "Value", "Text"), "Chọn loại", new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Type, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Note" class="control-label col-md-2"></label>
                <div class="col-md-10">
                    @Html.TextAreaFor(m => m.Note, new { @class = "form-control", placeholder = "Ghi chú (tùy chọn)" })
                    @Html.ValidationMessageFor(m => m.Note, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ReporterName" class="control-label col-md-2"></label>
                <div class="col-md-10">
                    @Html.TextBoxFor(m => m.ReporterName, new { @class = "form-control", placeholder = "Tên của bạn" })
                    @Html.ValidationMessageFor(m => m.ReporterName, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ReporterEmail" class="control-label col-md-2"></label>
                <div class="col-md-10">
                    @Html.TextBoxFor(m => m.ReporterEmail, new { @class = "form-control", placeholder = "Email của bạn" })
                    @Html.ValidationMessageFor(m => m.ReporterEmail, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-danger btn-lg">Gửi báo cáo</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/Scripts/jquery-3.6.0.min.js"></script>
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
}