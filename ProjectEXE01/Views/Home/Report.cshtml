@model DAL.Models.ReportViewModel
@{
    // Sử dụng ViewBag.Message và ViewBag.IsError đã được thiết lập trong HomeController
    ViewData["Title"] = "Gửi Báo cáo Lừa đảo";
}

<div class="container py-5">
    <h2 class="text-center mb-4 text-danger fw-bold">⚠️ Gửi Báo cáo Chống Lừa đảo</h2>

    <div class="card shadow p-4">

        @* Logic hiển thị thông báo đã được tối ưu *@
        @if (ViewBag.Message != null)
        {
            var alertClass = (ViewBag.IsError == true) ? "alert-danger" : "alert-success";

            <div class="alert @alertClass" role="alert">
                @ViewBag.Message
            </div>
        }
        @* Hết logic hiển thị thông báo đã được tối ưu *@

        @* SỬ DỤNG TAG HELPERS CHUẨN ASP.NET CORE MVC *@
        <form asp-controller="Home" asp-action="SubmitReport" method="post" class="form-horizontal">
            @* Dòng này tương đương với @Html.AntiForgeryToken() *@
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Query" class="control-label fw-bold"></label>
                <div>
                    <input asp-for="Query" class="form-control" placeholder="Nhập số điện thoại, STK hoặc link">
                    <span asp-validation-for="Query" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Type" class="control-label fw-bold"></label>
                <div>
                    @* Sử dụng <select> với Tag Helper cho DropDownList *@
                    <select asp-for="Type" class="form-control">
                        <option value="">Chọn loại báo cáo</option>
                        <option value="phone">Số điện thoại</option>
                        <option value="bank">Tài khoản ngân hàng</option>
                        <option value="link">Link/Website</option>
                    </select>
                    <span asp-validation-for="Type" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Note" class="control-label"></label>
                <div>
                    <textarea asp-for="Note" class="form-control" placeholder="Mô tả chi tiết về hành vi lừa đảo (tùy chọn)"></textarea>
                    <span asp-validation-for="Note" class="text-danger"></span>
                </div>
            </div>

            <hr />

            <div class="form-group mb-3">
                <label asp-for="ReporterName" class="control-label fw-bold"></label>
                <div>
                    <input asp-for="ReporterName" class="form-control" placeholder="Tên của bạn">
                    <span asp-validation-for="ReporterName" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ReporterEmail" class="control-label fw-bold"></label>
                <div>
                   
                    <input asp-for="ReporterEmail" class="form-control" type="text" placeholder="Email của bạn">
                    <span asp-validation-for="ReporterEmail" class="text-danger"></span>
                </div>
                <small class="form-text text-muted">Email này sẽ được dùng để xác định bạn là người báo cáo duy nhất cho mục này.</small>
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-danger btn-lg fw-bold">Gửi báo cáo</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}