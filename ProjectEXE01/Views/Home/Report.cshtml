@model DAL.Models.ReportViewModel
@{
    ViewData["Title"] = "Gửi Báo cáo Lừa đảo - Hệ thống AntiScam";
}

<style>
    /* Đồng bộ Background với Hero trang chủ */
    .report-page-wrapper {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        min-height: 100vh;
        padding: 80px 0;
        position: relative;
    }

        .report-page-wrapper::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at top right, rgba(231, 76, 60, 0.05) 0%, transparent 40%);
            z-index: 0;
        }

    /* Form Card Style */
    .report-card {
        background: #ffffff;
        border-radius: 24px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        padding: 50px;
        position: relative;
        z-index: 1;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .form-header-pro {
        margin-bottom: 40px;
    }

        .form-header-pro h2 {
            font-weight: 800;
            color: #1a1a2e;
            letter-spacing: -1px;
        }

    /* Section Styling */
    .report-section {
        background: #f8f9fc;
        border-radius: 16px;
        padding: 30px;
        margin-bottom: 30px;
        border: 1px solid #edf2f7;
        transition: all 0.3s ease;
    }

        .report-section:hover {
            border-color: #e2e8f0;
            background: #f1f5f9;
        }

    .section-label {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 700;
        color: #e74c3c;
        margin-bottom: 25px;
        text-transform: uppercase;
        font-size: 0.9rem;
        letter-spacing: 1px;
    }

    /* Input Styling */
    .form-group-pro {
        margin-bottom: 20px;
    }

    .form-label-pro {
        font-weight: 600;
        color: #4a5568;
        margin-bottom: 8px;
        font-size: 0.95rem;
    }

    .input-pro {
        border-radius: 12px !important;
        border: 2px solid #e2e8f0 !important;
        padding: 12px 16px !important;
        font-size: 1rem;
        transition: all 0.2s ease;
        background: #fff !important;
    }

        .input-pro:focus {
            border-color: #e74c3c !important;
            box-shadow: 0 0 0 4px rgba(231, 76, 60, 0.1) !important;
        }

    /* Button Styling */
    .btn-send-report {
        background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
        color: white;
        border: none;
        padding: 16px 50px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 1.1rem;
        box-shadow: 0 10px 20px rgba(231, 76, 60, 0.3);
        transition: all 0.3s ease;
    }

        .btn-send-report:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(231, 76, 60, 0.4);
            color: white;
        }

    /* Helper & Validation */
    .helper-pro {
        font-size: 0.85rem;
        color: #718096;
        margin-top: 6px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .text-danger {
        font-size: 0.85rem;
        font-weight: 500;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .report-card {
            padding: 30px 20px;
        }

        .form-header-pro h2 {
            font-size: 1.75rem;
        }
    }
</style>

<div class="report-page-wrapper">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="report-card animate__animated animate__fadeIn">

                    <div class="form-header-pro text-center">
                        <div class="mb-3">
                            <span class="badge bg-danger-soft text-danger px-3 py-2 rounded-pill fw-bold" style="background: rgba(231, 76, 60, 0.1);">
                                <i class="fas fa-shield-alt me-2"></i>CỘNG ĐỒNG BẢO MẬT
                            </span>
                        </div>
                        <h2>Gửi Báo Cáo Lừa Đảo</h2>
                        <p class="text-muted">Đóng góp của bạn là vũ khí mạnh nhất để loại bỏ tội phạm mạng.</p>
                    </div>

                    @if (ViewBag.Message != null)
                    {
                        var alertClass = (ViewBag.IsError == true) ? "alert-danger" : "alert-success";
                        <div class="alert @alertClass border-0 rounded-4 p-3 mb-4 shadow-sm animate__animated animate__shakeX">
                            <i class="fas @(ViewBag.IsError == true ? "fa-exclamation-circle" : "fa-check-circle") me-2"></i>
                            @ViewBag.Message
                        </div>
                    }

                    <form asp-controller="Home" asp-action="SubmitReport" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="report-section shadow-sm">
                            <div class="section-label">
                                <i class="fas fa-user-secret fs-5"></i>
                                Đối tượng nghi vấn
                            </div>

                            <div class="row">
                                <div class="col-md-7 form-group-pro">
                                    <label asp-for="Query" class="form-label-pro">Số điện thoại / STK / Link <span class="text-danger">*</span></label>
                                    <input asp-for="Query" class="form-control input-pro" placeholder="Ví dụ: 0912... hoặc https://...">
                                    <span asp-validation-for="Query" class="text-danger"></span>
                                    <div class="helper-pro"><i class="fas fa-info-circle text-primary"></i> Nhập chính xác thông tin cần tố cáo</div>
                                </div>

                                <div class="col-md-5 form-group-pro">
                                    <label asp-for="Type" class="form-label-pro">Loại hình <span class="text-danger">*</span></label>
                                    <select asp-for="Type" class="form-select input-pro">
                                        <option value="">-- Chọn loại --</option>
                                        <option value="phone">📱 Số điện thoại</option>
                                        <option value="bank">🏦 Tài khoản ngân hàng</option>
                                        <option value="link">🔗 Website lừa đảo</option>
                                    </select>
                                    <span asp-validation-for="Type" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="form-group-pro mt-2">
                                <label asp-for="Note" class="form-label-pro">Mô tả chi tiết hành vi</label>
                                <textarea asp-for="Note" class="form-control input-pro" style="min-height: 120px;" placeholder="Ví dụ: Giả danh công an gọi điện hăm dọa, gửi link bình chọn cuộc thi giả mạo..."></textarea>
                                <div class="helper-pro"><i class="fas fa-lightbulb text-warning"></i> Càng chi tiết, hệ thống càng nhanh chóng xác minh.</div>
                            </div>
                        </div>

                        <div class="report-section shadow-sm">
                            <div class="section-label" style="color: #2c3e50;">
                                <i class="fas fa-user-shield fs-5"></i>
                                Định danh người báo cáo
                            </div>

                            <div class="row">
                                <div class="col-md-6 form-group-pro">
                                    <label asp-for="ReporterName" class="form-label-pro">Họ và tên của bạn <span class="text-danger">*</span></label>
                                    <input asp-for="ReporterName" class="form-control input-pro" placeholder="Nhập tên đầy đủ">
                                    <span asp-validation-for="ReporterName" class="text-danger"></span>
                                </div>

                                <div class="col-md-6 form-group-pro">
                                    <label asp-for="ReporterEmail" class="form-label-pro">Địa chỉ Email <span class="text-danger">*</span></label>
                                    <input asp-for="ReporterEmail" class="form-control input-pro" type="email" placeholder="example@email.com">
                                    <span asp-validation-for="ReporterEmail" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="mt-2 py-2 px-3 rounded-3" style="background: #eef2f7; border-left: 4px solid #3498db;">
                                <p class="mb-0 small text-muted">
                                    <i class="fas fa-lock me-2 text-primary"></i>
                                    <strong>Cam kết bảo mật:</strong> Danh tính của bạn được mã hóa và chỉ phục vụ mục đích xác thực báo cáo.
                                </p>
                            </div>
                        </div>

                        <div class="text-center mt-5">
                            <button type="submit" class="btn btn-send-report">
                                <i class="fas fa-paper-plane me-2"></i>GỬI BÁO CÁO NGAY
                            </button>
                            <p class="mt-4 text-muted small">
                                Bằng việc nhấn gửi, bạn cam đoan thông tin trên là đúng sự thật.
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}