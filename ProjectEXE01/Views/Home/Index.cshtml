@{
    ViewBag.Title = "AntiScam - Hệ thống cảnh báo lừa đảo toàn diện";
    var userEmail = Context.Session.GetString("UserEmail");
}

<style>
    /* Custom Styles for Professional Look */
    .hero-gradient {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        padding: 100px 0;
        position: relative;
        overflow: hidden;
    }

        .hero-gradient::after {
            content: "";
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(231, 76, 60, 0.05) 0%, transparent 70%);
            z-index: 1;
        }

    .search-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .custom-input {
        border-radius: 12px 0 0 12px !important;
        border: 2px solid transparent !important;
        transition: all 0.3s;
    }

        .custom-input:focus {
            border-color: #e74c3c !important;
            background: #fff !important;
        }

    .btn-modern {
        border-radius: 0 12px 12px 0 !important;
        padding: 0 30px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .feature-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 20px !important;
    }

        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1) !important;
        }

    .vip-badge {
        background: linear-gradient(45deg, #f1c40f, #f39c12);
        color: #000;
        font-weight: 700;
        border: none;
    }
</style>

<section class="hero-gradient text-center">
    <div class="container" style="position: relative; z-index: 2;">
        @if (userEmail != null)
        {
            bool isVip = ViewBag.IsVip ?? false;
            <div class="mb-4 animate__animated animate__fadeInDown">
                @if (isVip)
                {
                    <span class="badge vip-badge rounded-pill px-4 py-2 shadow-lg">
                        <i class="fas fa-crown me-2"></i>THÀNH VIÊN VIP: @userEmail
                    </span>
                }
                else
                {
                    <span class="badge bg-light text-dark rounded-pill px-4 py-2 shadow-sm border">
                        <i class="fas fa-user-circle me-2 text-primary"></i>Chào mừng trở lại, @userEmail
                    </span>
                }
            </div>
        }

        <h1 class="display-3 fw-bold text-white mb-3">Bảo vệ bạn trước <span class="text-danger">Lừa Đảo</span></h1>
        <p class="lead text-white-50 mx-auto mb-5" style="max-width: 650px;">
            Hệ thống tra cứu thông minh giúp nhận diện số điện thoại, số tài khoản và website độc hại trong tích tắc.
        </p>

        <div class="search-card mx-auto mb-4" style="max-width: 800px;">
            @if (userEmail == null)
            {
                <div class="alert alert-soft-danger d-flex align-items-center justify-content-center mb-4 py-3 border-0 rounded-4 shadow-sm" style="background: rgba(231, 76, 60, 0.1); color: #ff7675;">
                    <i class="fas fa-shield-alt me-3 fs-4"></i>
                    <span>Bạn cần <a asp-controller="Account" asp-action="Login" class="text-white fw-bold text-decoration-underline">Đăng nhập</a> để bắt đầu bảo vệ cộng đồng.</span>
                </div>
            }

            <form asp-controller="Home" asp-action="Check" method="post">
                <div class="input-group input-group-lg shadow-lg">
                    <input type="text" name="query" class="form-control custom-input py-4 px-4 shadow-none"
                           placeholder="Nhập số điện thoại, STK, link..." required
                           @(userEmail == null ? "disabled" : "")>
                    <button class="btn btn-danger btn-modern fw-bold" type="submit" @(userEmail == null ? "disabled" : "")>
                        Kiểm tra ngay
                    </button>
                </div>
            </form>
            @* --- KẾT QUẢ AN TOÀN --- *@
            @if (ViewBag.IsSafe == true)
            {
                <div class="mt-4 animate__animated animate__fadeInUp text-start">
                    <div class="alert safe-alert p-4 d-flex align-items-center">
                        <div class="rounded-circle bg-success p-3 me-4 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px; min-width: 60px;">
                            <i class="fas fa-shield-check text-white fs-3 pulse-shield"></i>
                        </div>
                        <div>
                            <h5 class="text-success fw-bold mb-1">Chưa có báo cáo vi phạm</h5>
                            <p class="text-white-50 mb-0 small">Thông tin <strong class="text-white">"@ViewBag.LastQuery"</strong> hiện chưa có trong danh sách đen. Hãy luôn cảnh giác!</p>
                        </div>
                    </div>
                </div>
            }

            @* --- THÔNG BÁO LỖI / NHẮC NHỞ --- *@
            @if (ViewBag.IsError == true)
            {
                <div class="alert alert-danger mt-4 border-0 rounded-4 shadow-sm animate__animated animate__shakeX">
                    <i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Message
                </div>
            }
            @if (userEmail != null)
            {
                bool isVip = ViewBag.IsVip ?? false;
                int remaining = ViewBag.RemainingSearches ?? 0;

                <div class="mt-4 d-flex justify-content-center align-items-center text-white-50 small">
                    @if (isVip)
                    {
                        <div class="d-flex align-items-center text-warning">
                            <i class="fas fa-infinity fs-5 me-2"></i>
                            <strong>Đặc quyền VIP: Tra cứu không giới hạn</strong>
                        </div>
                    }
                    else
                    {
                        <span>Bạn còn <strong class="text-danger">@remaining lượt</strong> miễn phí.</span>
                        <a asp-controller="Account" asp-action="UpgradeVip" class="btn btn-sm btn-outline-warning ms-3 rounded-pill px-3">
                            Nâng cấp VIP
                        </a>
                    }
                </div>
            }
        </div>

        <p class="text-white-50 x-small">
            <i class="fas fa-check-double me-2 text-success"></i>Dữ liệu thời thực được xác thực bởi Admin và Cộng đồng AntiScam.
        </p>
    </div>
</section>

<section class="py-5 bg-white">
    <div class="container py-4">
        <div class="row align-items-center mb-5">
            <div class="col-lg-6">
                <h6 class="text-danger fw-bold text-uppercase ls-2">Dịch vụ cốt lõi</h6>
                <h2 class="display-6 fw-bold mb-4">Giải pháp an ninh trực tuyến</h2>
            </div>
            <div class="col-lg-6 text-lg-end">
                <p class="text-muted">Chúng tôi cung cấp các công cụ mạnh mẽ hoàn toàn miễn phí để giúp bạn tự tin hơn khi thực hiện các giao dịch trên không gian số.</p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm feature-card p-4">
                    <div class="card-body">
                        <div class="mb-4 bg-danger-soft rounded-4 d-inline-block p-3" style="background: #fff5f5;">
                            <i class="fas fa-bolt text-danger fs-3"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Cảnh báo tức thì</h4>
                        <p class="text-muted mb-4">Nhận thông tin mới nhất về các chiến dịch lừa đảo đang diễn ra tại Việt Nam.</p>
                        <a asp-controller="Home" asp-action="News" class="text-danger text-decoration-none fw-bold">
                            Tìm hiểu thêm <i class="fas fa-chevron-right ms-1 small"></i>
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm feature-card p-4">
                    <div class="card-body">
                        <div class="mb-4 bg-primary-soft rounded-4 d-inline-block p-3" style="background: #f0f7ff;">
                            <i class="fas fa-book-open text-primary fs-3"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Cẩm nang bảo mật</h4>
                        <p class="text-muted mb-4">Thư viện tài liệu giúp bạn nhận biết 24 hình thức lừa đảo phổ biến nhất hiện nay.</p>
                        <a asp-controller="Home" asp-action="Resources" class="text-primary text-decoration-none fw-bold">
                            Khám phá ngay <i class="fas fa-chevron-right ms-1 small"></i>
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm feature-card p-4 border-top border-5 border-success">
                    <div class="card-body">
                        <div class="mb-4 bg-success-soft rounded-4 d-inline-block p-3" style="background: #f1fbf4;">
                            <i class="fas fa-medal text-success fs-3"></i>
                        </div>
                        <h4 class="fw-bold mb-3">BXH Đóng góp</h4>
                        <p class="text-muted mb-4">Vinh danh những cá nhân tích cực báo cáo, chung tay xây dựng internet sạch.</p>
                        <a asp-controller="Home" asp-action="Ranking" class="text-success text-decoration-none fw-bold">
                            Xem xếp hạng <i class="fas fa-chevron-right ms-1 small"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-5 p-5 rounded-5 shadow-lg bg-danger text-white text-center animate__animated animate__pulse animate__infinite animate__slower" style="animation-duration: 5s;">
            <h3 class="fw-bold mb-3">Phát hiện lừa đảo? Hãy lên tiếng ngay!</h3>
            <p class="mb-4 opacity-75">Hành động nhỏ của bạn có thể cứu hàng trăm người khác khỏi mất tiền oan.</p>
            <a asp-controller="Home" asp-action="Report" class="btn btn-light btn-lg px-5 py-3 fw-bold rounded-pill text-danger">
                GỬI BÁO CÁO NGAY
            </a>
        </div>
    </div>
</section>

<section class="py-5 border-top bg-light">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <div class="pe-lg-5">
                    <h2 class="fw-bold mb-4">Tại sao cộng đồng tin dùng AntiScam?</h2>
                    <div class="d-flex mb-4">
                        <div class="me-3"><i class="fas fa-check-circle text-success fs-4"></i></div>
                        <div>
                            <h6 class="fw-bold">Hoàn toàn miễn phí</h6>
                            <p class="text-muted small">Mục tiêu duy nhất là bảo vệ cộng đồng, không vì mục đích lợi nhuận.</p>
                        </div>
                    </div>
                    <div class="d-flex mb-4">
                        <div class="me-3"><i class="fas fa-check-circle text-success fs-4"></i></div>
                        <div>
                            <h6 class="fw-bold">Dữ liệu tin cậy</h6>
                            <p class="text-muted small">Cơ sở dữ liệu được đối soát từ nhiều nguồn cơ quan chức năng và người dùng thật.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 text-center">
                <img src="https://img.icons8.com/illustrations/external-faticon-flat-flat-icons/256/external-shield-cyber-security-faticon-flat-flat-icons-3.png" alt="Shield" class="img-fluid opacity-50" style="max-height: 300px;">
            </div>
        </div>
    </div>
</section>