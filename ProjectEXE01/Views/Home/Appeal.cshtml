@model DAL.Models.AppealViewModel
@{
    ViewData["Title"] = "Gửi Yêu cầu Khiếu nại";
}

<style>
    .appeal-form-page {
        background: linear-gradient(135deg, #f0f8ff 0%, #e3f2fd 100%);
        min-height: calc(100vh - 200px);
        padding: 3rem 0;
    }

    .form-header {
        text-align: center;
        margin-bottom: 3rem;
        animation: fadeInDown 0.8s ease;
    }

        .form-header h2 {
            font-size: 2.5rem;
            font-weight: 800;
            color: #0d6efd;
            margin-bottom: 1rem;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
        }

        .form-header .subtitle {
            font-size: 1.1rem;
            color: #6c757d;
            max-width: 700px;
            margin: 0 auto;
        }

    .form-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(13, 110, 253, 0.15);
        padding: 3rem;
        max-width: 800px;
        margin: 0 auto;
        animation: fadeInUp 0.8s ease;
        border: 2px solid rgba(13, 110, 253, 0.1);
    }

    .info-banner {
        background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
        padding: 1.5rem;
        border-radius: 15px;
        border-left: 5px solid #0d6efd;
        margin-bottom: 2rem;
    }

        .info-banner h5 {
            color: #0d6efd;
            font-weight: 700;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .info-banner ul {
            margin-bottom: 0;
            padding-left: 1.5rem;
        }

        .info-banner li {
            color: #495057;
            margin-bottom: 0.5rem;
        }

    .form-section {
        background: #f8f9fa;
        padding: 2rem;
        border-radius: 15px;
        margin-bottom: 2rem;
        border-left: 5px solid #0d6efd;
    }

    .form-section-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #0d6efd;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-label {
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .form-label .required {
            color: #dc3545;
            font-size: 1.2rem;
        }

    .form-control, .form-select {
        border-radius: 10px;
        border: 2px solid #e9ecef;
        padding: 0.75rem 1rem;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

        .form-control:focus, .form-select:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.15);
        }

    textarea.form-control {
        resize: vertical;
        min-height: 150px;
    }

    .btn-submit {
        background: linear-gradient(135deg, #0d6efd 0%, #0b5ed7 100%);
        border: none;
        padding: 1rem 3rem;
        font-size: 1.2rem;
        font-weight: 700;
        border-radius: 50px;
        box-shadow: 0 8px 25px rgba(13, 110, 253, 0.4);
        transition: all 0.3s ease;
        color: white;
    }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 35px rgba(13, 110, 253, 0.6);
            background: linear-gradient(135deg, #0b5ed7 0%, #0a58ca 100%);
        }

    .helper-text {
        font-size: 0.9rem;
        color: #6c757d;
        margin-top: 0.5rem;
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }

    .alert {
        border-radius: 15px;
        border: none;
        padding: 1.25rem;
        animation: slideInDown 0.5s ease;
        margin-bottom: 2rem;
    }

        .alert i {
            font-size: 1.2rem;
        }

    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes slideInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 768px) {
        .form-card {
            padding: 2rem 1.5rem;
        }

        .form-header h2 {
            font-size: 2rem;
        }

        .btn-submit {
            padding: 0.875rem 2rem;
            font-size: 1.1rem;
        }
    }
</style>

<div class="appeal-form-page">
    <div class="container">
        <div class="form-header">
            <h2>
                <i class="fas fa-balance-scale me-2"></i>
                Gửi Yêu cầu Khiếu nại
            </h2>
            <p class="subtitle">
                <i class="fas fa-shield-halved me-2 text-primary"></i>
                Chúng tôi cam kết xem xét công bằng mọi khiếu nại và xác minh lại thông tin
            </p>
        </div>

        <div class="form-card">
            @if (ViewBag.Message != null)
            {
                var alertClass = (ViewBag.IsError == true) ? "alert-danger" : "alert-success";
                var iconClass = (ViewBag.IsError == true) ? "fa-exclamation-circle" : "fa-check-circle";

                <div class="alert @alertClass" role="alert">
                    <i class="fas @iconClass me-2"></i>
                    @ViewBag.Message
                </div>
            }

            <div class="info-banner">
                <h5>
                    <i class="fas fa-info-circle"></i>
                    Khi nào bạn nên gửi khiếu nại?
                </h5>
                <ul>
                    <li><i class="fas fa-check text-primary me-2"></i>Bạn bị báo cáo nhầm và có bằng chứng chứng minh</li>
                    <li><i class="fas fa-check text-primary me-2"></i>Thông tin trên hệ thống không chính xác về bạn</li>
                    <li><i class="fas fa-check text-primary me-2"></i>Bạn muốn cung cấp giải trình rõ ràng về tình huống</li>
                </ul>
            </div>

            <form asp-controller="Home" asp-action="SubmitAppeal" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- Thông tin khiếu nại -->
                <div class="form-section">
                    <div class="form-section-title">
                        <i class="fas fa-file-alt"></i>
                        Thông tin khiếu nại
                    </div>

                    <div class="mb-4">
                        <label asp-for="Query" class="form-label">
                            <i class="fas fa-search"></i>
                            Số điện thoại / STK / Link bị báo cáo
                            <span class="required">*</span>
                        </label>
                        <input asp-for="Query" class="form-control" placeholder="Nhập chính xác thông tin đã bị báo cáo">
                        <span asp-validation-for="Query" class="text-danger"></span>
                        <div class="helper-text">
                            <i class="fas fa-exclamation-triangle text-warning"></i>
                            <span>Thông tin này phải trùng khớp với mục đã bị báo cáo trên hệ thống</span>
                        </div>
                    </div>

                    <div class="mb-0">
                        <label asp-for="Reason" class="form-label">
                            <i class="fas fa-comment-dots"></i>
                            Lý do khiếu nại & Bằng chứng
                            <span class="required">*</span>
                        </label>
                        <textarea asp-for="Reason" class="form-control" placeholder="Nêu rõ lý do khiếu nại:&#10;&#10;1. Tại sao bạn cho rằng báo cáo là không chính xác?&#10;2. Bạn có bằng chứng gì để chứng minh?&#10;3. Giải trình chi tiết về tình huống..."></textarea>
                        <span asp-validation-for="Reason" class="text-danger"></span>
                        <div class="helper-text">
                            <i class="fas fa-lightbulb text-warning"></i>
                            <span>Cung cấp bằng chứng càng chi tiết càng giúp quá trình xử lý nhanh hơn (ảnh chụp màn hình, email, tin nhắn...)</span>
                        </div>
                    </div>
                </div>

                <!-- Thông tin người khiếu nại -->
                <div class="form-section">
                    <div class="form-section-title">
                        <i class="fas fa-user"></i>
                        Thông tin người khiếu nại
                    </div>

                    <div class="mb-4">
                        <label asp-for="AppellantName" class="form-label">
                            <i class="fas fa-user-circle"></i>
                            Tên của bạn
                            <span class="required">*</span>
                        </label>
                        <input asp-for="AppellantName" class="form-control" placeholder="Nhập họ tên đầy đủ">
                        <span asp-validation-for="AppellantName" class="text-danger"></span>
                    </div>

                    <div class="mb-0">
                        <label asp-for="AppellantEmail" class="form-label">
                            <i class="fas fa-envelope"></i>
                            Email liên hệ
                            <span class="required">*</span>
                        </label>
                        <input asp-for="AppellantEmail" class="form-control" type="email" placeholder="example@email.com">
                        <span asp-validation-for="AppellantEmail" class="text-danger"></span>
                        <div class="helper-text">
                            <i class="fas fa-bell text-info"></i>
                            <span>Chúng tôi sẽ gửi thông báo kết quả xử lý khiếu nại qua email này</span>
                        </div>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-submit">
                        <i class="fas fa-paper-plane me-2"></i>
                        Gửi Khiếu Nại
                    </button>
                </div>

                <div class="text-center mt-4">
                    <p class="text-muted small mb-0">
                        <i class="fas fa-clock text-primary me-1"></i>
                        Thời gian xử lý khiếu nại: 3-5 ngày làm việc
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}