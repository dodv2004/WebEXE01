@model DAL.Models.AppealViewModel
@{
    ViewData["Title"] = "Gửi Yêu cầu Khiếu nại - Hệ thống AntiScam";
}

<style>
    /* Đồng bộ Background với hệ thống */
    .appeal-page-wrapper {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        min-height: 100vh;
        padding: 80px 0;
        position: relative;
    }

        .appeal-page-wrapper::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at bottom left, rgba(52, 152, 219, 0.05) 0%, transparent 40%);
            z-index: 0;
        }

    /* Card Style */
    .appeal-card {
        background: #ffffff;
        border-radius: 24px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        padding: 50px;
        position: relative;
        z-index: 1;
    }

    .header-pro {
        margin-bottom: 40px;
    }

        .header-pro h2 {
            font-weight: 800;
            color: #1a1a2e;
            letter-spacing: -1px;
        }

    /* Banner hướng dẫn */
    .info-banner-pro {
        background: #f0f7ff;
        padding: 25px;
        border-radius: 16px;
        border-left: 5px solid #3498db;
        margin-bottom: 35px;
    }

        .info-banner-pro h5 {
            color: #2980b9;
            font-weight: 700;
            font-size: 1.1rem;
            margin-bottom: 12px;
        }

        .info-banner-pro ul li {
            color: #4a5568;
            font-size: 0.95rem;
            margin-bottom: 8px;
        }

    /* Section Styling */
    .appeal-section {
        background: #f8f9fc;
        border-radius: 16px;
        padding: 30px;
        margin-bottom: 30px;
        border: 1px solid #edf2f7;
    }

    .section-label {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 700;
        color: #3498db;
        margin-bottom: 25px;
        text-transform: uppercase;
        font-size: 0.9rem;
        letter-spacing: 1px;
    }

    /* Input & Form Styling */
    .form-label-pro {
        font-weight: 600;
        color: #4a5568;
        margin-bottom: 8px;
        font-size: 0.95rem;
    }

    .input-pro {
        border-radius: 12px !important;
        border: 2px solid #e2e8f0 !important;
        padding: 12px 16px !important;
        transition: all 0.2s ease;
    }

        .input-pro:focus {
            border-color: #3498db !important;
            box-shadow: 0 0 0 4px rgba(52, 152, 219, 0.1) !important;
        }

    /* Button Style */
    .btn-submit-appeal {
        background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
        color: white;
        border: none;
        padding: 16px 50px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 1.1rem;
        box-shadow: 0 10px 20px rgba(52, 152, 219, 0.2);
        transition: all 0.3s ease;
    }

        .btn-submit-appeal:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(52, 152, 219, 0.3);
            color: white;
        }

    .helper-pro {
        font-size: 0.85rem;
        color: #718096;
        margin-top: 8px;
        display: flex;
        gap: 8px;
    }

    @@media (max-width: 768px) {
        .appeal-card {
            padding: 30px 20px;
        }
    }
</style>

<div class="appeal-page-wrapper">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="appeal-card animate__animated animate__fadeIn">

                    <div class="header-pro text-center">
                        <div class="mb-3">
                            <span class="badge px-3 py-2 rounded-pill fw-bold" style="background: rgba(52, 152, 219, 0.1); color: #3498db;">
                                <i class="fas fa-balance-scale me-2"></i>TRUNG TÂM KHIẾU NẠI
                            </span>
                        </div>
                        <h2>Yêu Cầu Xem Xét Lại</h2>
                        <p class="text-muted">Chúng tôi luôn lắng nghe và cam kết sự công bằng trong việc xác thực dữ liệu.</p>
                    </div>

                    @if (ViewBag.Message != null)
                    {
                        var alertClass = (ViewBag.IsError == true) ? "alert-danger" : "alert-success";
                        <div class="alert @alertClass border-0 rounded-4 p-3 mb-4 shadow-sm">
                            <i class="fas @(ViewBag.IsError == true ? "fa-exclamation-circle" : "fa-check-circle") me-2"></i>
                            @ViewBag.Message
                        </div>
                    }

                    <div class="info-banner-pro shadow-sm">
                        <h5><i class="fas fa-info-circle me-2"></i>Bạn nên gửi khiếu nại nếu:</h5>
                        <ul class="list-unstyled mb-0">
                            <li><i class="fas fa-check-circle text-primary me-2"></i>Số điện thoại hoặc tài khoản của bạn bị báo cáo nhầm.</li>
                            <li><i class="fas fa-check-circle text-primary me-2"></i>Thông tin mô tả hành vi lừa đảo không đúng sự thật.</li>
                            <li><i class="fas fa-check-circle text-primary me-2"></i>Bạn đã giải quyết xong tranh chấp và muốn gỡ bỏ thông tin.</li>
                        </ul>
                    </div>

                    <form asp-controller="Home" asp-action="SubmitAppeal" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="appeal-section">
                            <div class="section-label">
                                <i class="fas fa-file-invoice fs-5"></i>
                                Chi tiết khiếu nại
                            </div>

                            <div class="mb-4">
                                <label asp-for="Query" class="form-label-pro">Số điện thoại / STK / Link cần gỡ bỏ <span class="text-danger">*</span></label>
                                <input asp-for="Query" class="form-control input-pro" placeholder="Nhập chính xác thông tin bị báo cáo">
                                <span asp-validation-for="Query" class="text-danger"></span>
                                <div class="helper-pro">
                                    <i class="fas fa-exclamation-triangle text-warning"></i>
                                    <span>Thông tin phải khớp hoàn toàn với dữ liệu trên hệ thống.</span>
                                </div>
                            </div>

                            <div class="mb-0">
                                <label asp-for="Reason" class="form-label-pro">Lý do & Bằng chứng giải trình <span class="text-danger">*</span></label>
                                <textarea asp-for="Reason" class="form-control input-pro" style="min-height: 160px;"
                                          placeholder="Vui lòng nêu rõ lý do và cung cấp các bằng chứng như hình ảnh, email (dạng link hoặc mô tả) để chúng tôi đối soát..."></textarea>
                                <span asp-validation-for="Reason" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="appeal-section">
                            <div class="section-label" style="color: #2c3e50;">
                                <i class="fas fa-id-card fs-5"></i>
                                Thông tin liên hệ
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="AppellantName" class="form-label-pro">Họ và tên <span class="text-danger">*</span></label>
                                    <input asp-for="AppellantName" class="form-control input-pro" placeholder="Họ tên người yêu cầu">
                                    <span asp-validation-for="AppellantName" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="AppellantEmail" class="form-label-pro">Email nhận kết quả <span class="text-danger">*</span></label>
                                    <input asp-for="AppellantEmail" class="form-control input-pro" type="email" placeholder="example@email.com">
                                    <span asp-validation-for="AppellantEmail" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="text-center mt-5">
                            <button type="submit" class="btn btn-submit-appeal">
                                <i class="fas fa-paper-plane me-2"></i>XÁC NHẬN GỬI KHIẾU NẠI
                            </button>
                            <div class="mt-4 d-flex justify-content-center gap-4 text-muted small">
                                <span><i class="fas fa-clock me-1 text-primary"></i> Xử lý trong 3-5 ngày</span>
                                <span><i class="fas fa-user-check me-1 text-success"></i> Thẩm định thủ công</span>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}