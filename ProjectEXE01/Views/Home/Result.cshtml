@model DAL.Models.Result

@{
    ViewData["Title"] = "Kết quả tra cứu: " + Model.Query;

    // Hàm tiện ích nhỏ để chuyển đổi Type
    string GetVietnameseType(string type) => type switch
    {
        "phone" => "Số điện thoại",
        "bank" => "Tài khoản ngân hàng",
        "link" => "Đường link/Website",
        _ => "Không xác định"
    };
}

<div class="container py-5">
    <h2 class="text-center mb-4 text-primary fw-bold">KẾT QUẢ TRA CỨU</h2>

    <div class="card shadow p-4">
        <h5 class="mb-3">Thông tin bạn tra cứu:</h5>
        <p><strong>🔍 Từ khóa:</strong> <span class="text-break">@Model.Query</span></p>
        <hr class="mb-4" />

        @if (Model.Found)
        {
            // Phân loại cảnh báo dựa trên Verdict (đã được Service cập nhật)
            var alertClass = "alert-info"; // Mặc định là Info
            var icon = "ℹ️";

            if (Model.Verdict.Contains("CẢNH BÁO CAO") || Model.Verdict.Contains("lừa đảo"))
            {
                alertClass = "alert-danger";
                icon = "⚠️";
            }
            else if (Model.Verdict.Contains("Chờ xác minh"))
            {
                alertClass = "alert-warning";
                icon = "🚨";
            }

            <div class="alert @alertClass">
                <h5>@icon Đã tìm thấy báo cáo liên quan!</h5>
                <p><strong>Loại:</strong> @GetVietnameseType(Model.Type)</p>
                <p class="fw-bold"><strong>Trạng thái:</strong> @Model.Verdict</p>
                <p><strong>Số lần bị báo cáo:</strong> <span class="badge bg-danger">@Model.ReportCount</span></p>
                <p><strong>Báo cáo gần nhất:</strong> @Model.CheckedAt.ToString("dd/MM/yyyy HH:mm")</p>

                @if (Model.Reporters.Any())
                {
                    <hr />
                    <p><strong>Người báo cáo đã được ghi nhận:</strong></p>
                    <small class="text-muted">*(Chúng tôi chỉ hiển thị tên người báo cáo để đảm bảo quyền riêng tư)</small>
                    <ul>
                        @foreach (var reporter in Model.Reporters)
                        {
                            <li>@reporter</li>
                        }
                    </ul>
                }

                <hr />
                <p class="fw-bold">
                    👉 <a href="@Url.Action("Report", "Home", new { query = Model.Query })" class="alert-link">
                        Bạn muốn gửi thêm chi tiết về báo cáo này? Nhấn vào đây.
                    </a>
                </p>
            </div>
        }
        else
        {
            <div class="alert alert-success">
                <h5>✅ Kết quả: @Model.Verdict</h5>
                <p>Số này / Tài khoản / Link chưa từng bị báo cáo trên hệ thống.</p>
                <p class="mt-3 fw-bold">
                    🛡️ <a href="@Url.Action("Report", "Home", new { query = Model.Query })" class="alert-link text-success">
                        Nếu bạn là nạn nhân, hãy báo cáo ngay để giúp cộng đồng!
                    </a>
                </p>
            </div>
        }

        <div class="text-center mt-4">
            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-primary btn-lg">🔙 Tra cứu mục khác</a>
        </div>
    </div>
</div>