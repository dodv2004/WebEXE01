@model DAL.Models.Result
@{
    ViewData["Title"] = "Kết quả tra cứu: " + Model.Query;

    // Hàm tiện ích nhỏ để chuyển đổi Type
    string GetVietnameseType(string type) => type switch
    {
        "phone" => "Số điện thoại",
        "bank" => "Tài khoản ngân hàng",
        "link" => "Đường link/Website",
        _ => "Không xác định"
    };

    // Xác định icon cho từng loại
    string GetTypeIcon(string type) => type switch
    {
        "phone" => "fa-phone",
        "bank" => "fa-building-columns",
        "link" => "fa-link",
        _ => "fa-question-circle"
    };
}

<style>
    .result-page {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        min-height: calc(100vh - 200px);
        padding: 3rem 0;
    }

    .result-header {
        text-align: center;
        margin-bottom: 3rem;
        animation: fadeInDown 0.8s ease;
    }

        .result-header h2 {
            font-size: 2.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 1rem;
        }

        .result-header .search-query {
            font-size: 1.2rem;
            color: #495057;
            background: white;
            padding: 1rem 2rem;
            border-radius: 50px;
            display: inline-block;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            max-width: 90%;
            word-break: break-all;
        }

    .result-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        padding: 3rem;
        max-width: 900px;
        margin: 0 auto;
        animation: fadeInUp 0.8s ease;
    }

    .query-info {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 2rem;
        border-radius: 15px;
        margin-bottom: 2rem;
        border-left: 5px solid #0d6efd;
    }

        .query-info h5 {
            color: #0d6efd;
            font-weight: 700;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .query-info p {
            margin-bottom: 0.5rem;
            font-size: 1.05rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .query-info strong {
            min-width: 120px;
            color: #2c3e50;
        }

    /* Alert Styles */
    .result-alert {
        border-radius: 15px;
        border: none;
        padding: 2rem;
        margin-bottom: 2rem;
        animation: slideInDown 0.5s ease;
        position: relative;
        overflow: hidden;
    }

        .result-alert::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 5px;
            background: linear-gradient(90deg, transparent, currentColor, transparent);
        }

    .alert-danger::before {
        color: #dc3545;
    }

    .alert-warning::before {
        color: #ffc107;
    }

    .alert-success::before {
        color: #198754;
    }

    .alert-info::before {
        color: #0dcaf0;
    }

    .result-alert h5 {
        font-size: 1.8rem;
        font-weight: 800;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

        .result-alert h5 .icon {
            font-size: 2.5rem;
        }

    .result-alert p {
        font-size: 1.05rem;
        line-height: 1.7;
        margin-bottom: 1rem;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-radius: 50px;
        font-weight: 700;
        font-size: 1.1rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
        margin: 0.5rem 0;
    }

    .report-count {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        color: white;
        padding: 0.5rem 1.25rem;
        border-radius: 50px;
        font-size: 1.2rem;
        font-weight: 700;
        display: inline-block;
        box-shadow: 0 4px 15px rgba(220, 53, 69, 0.3);
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.05);
        }
    }

    .reporters-section {
        background: #f8f9fa;
        padding: 1.5rem;
        border-radius: 15px;
        margin-top: 1.5rem;
    }

        .reporters-section h6 {
            font-weight: 700;
            color: #495057;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

    .reporters-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 0.75rem;
    }

        .reporters-list li {
            background: white;
            padding: 0.75rem 1rem;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

    .cta-section {
        background: linear-gradient(135deg, #fff3cd 0%, #ffe69c 100%);
        padding: 1.5rem;
        border-radius: 15px;
        margin-top: 1.5rem;
        border: 2px solid #ffc107;
        text-align: center;
    }

        .cta-section p {
            margin-bottom: 0;
            font-size: 1.1rem;
        }

        .cta-section a {
            font-weight: 700;
            text-decoration: none;
            color: #dc3545;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.3s ease;
        }

            .cta-section a:hover {
                transform: translateX(5px);
                color: #c82333;
            }

    .success-cta {
        background: linear-gradient(135deg, #d1e7dd 0%, #a3cfbb 100%);
        border: 2px solid #198754;
    }

        .success-cta a {
            color: #198754;
        }

            .success-cta a:hover {
                color: #146c43;
            }

    .action-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 3rem;
    }

    .btn-custom {
        padding: 1rem 2.5rem;
        font-size: 1.1rem;
        font-weight: 700;
        border-radius: 50px;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    }

        .btn-custom:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.2);
        }

    .divider {
        height: 2px;
        background: linear-gradient(90deg, transparent, #dee2e6, transparent);
        margin: 2rem 0;
    }

    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes slideInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 768px) {
        .result-card {
            padding: 2rem 1.5rem;
        }

        .result-header h2 {
            font-size: 2rem;
        }

        .result-header .search-query {
            font-size: 1rem;
            padding: 0.75rem 1.5rem;
        }

        .result-alert h5 {
            font-size: 1.4rem;
        }

        .reporters-list {
            grid-template-columns: 1fr;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn-custom {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="result-page">
    <div class="container">
        <div class="result-header">
            <h2>
                <i class="fas fa-search-plus me-2"></i>
                KẾT QUẢ TRA CỨU
            </h2>
            <div class="search-query">
                <i class="fas fa-quote-left me-2 text-muted"></i>
                <strong>@Model.Query</strong>
                <i class="fas fa-quote-right ms-2 text-muted"></i>
            </div>
        </div>

        <div class="result-card">
            <div class="query-info">
                <h5>
                    <i class="fas fa-info-circle"></i>
                    Thông tin tra cứu
                </h5>
                <p>
                    <strong><i class="fas fa-search"></i> Từ khóa:</strong>
                    <span class="text-break">@Model.Query</span>
                </p>
                <p>
                    <strong><i class="fas @GetTypeIcon(Model.Type)"></i> Loại:</strong>
                    <span>@GetVietnameseType(Model.Type)</span>
                </p>
                <p>
                    <strong><i class="far fa-clock"></i> Thời gian:</strong>
                    <span>@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
                </p>
            </div>

            <div class="divider"></div>

            @if (Model.Found)
            {
                // Phân loại cảnh báo dựa trên Verdict
                var alertClass = "alert-info";
                var icon = "ℹ️";
                var iconClass = "fa-info-circle";
                var statusColor = "info";

                if (Model.Verdict.Contains("CẢNH BÁO CAO") || Model.Verdict.Contains("lừa đảo"))
                {
                    alertClass = "alert-danger";
                    icon = "⚠️";
                    iconClass = "fa-triangle-exclamation";
                    statusColor = "danger";
                }
                else if (Model.Verdict.Contains("Chờ xác minh"))
                {
                    alertClass = "alert-warning";
                    icon = "🚨";
                    iconClass = "fa-exclamation-triangle";
                    statusColor = "warning";
                }

                <div class="result-alert @alertClass">
                    <h5>
                        <span class="icon">@icon</span>
                        <span>Đã tìm thấy báo cáo liên quan!</span>
                    </h5>

                    <p>
                        <i class="fas @GetTypeIcon(Model.Type) me-2"></i>
                        <strong>Loại:</strong> @GetVietnameseType(Model.Type)
                    </p>

                    <p>
                        <i class="fas fa-clipboard-check me-2"></i>
                        <strong>Trạng thái:</strong>
                        <span class="status-badge bg-@statusColor text-white">
                            <i class="fas @iconClass"></i>
                            @Model.Verdict
                        </span>
                    </p>

                    <p>
                        <i class="fas fa-flag me-2"></i>
                        <strong>Số lần bị báo cáo:</strong>
                        <span class="report-count">
                            <i class="fas fa-exclamation-circle me-1"></i>
                            @Model.ReportCount lần
                        </span>
                    </p>

                    <p>
                        <i class="far fa-calendar-alt me-2"></i>
                        <strong>Báo cáo gần nhất:</strong>
                        <span class="badge bg-secondary">@Model.CheckedAt.ToString("dd/MM/yyyy HH:mm")</span>
                    </p>

                    @if (Model.Reporters.Any())
                    {
                        <div class="reporters-section">
                            <h6>
                                <i class="fas fa-users"></i>
                                Người báo cáo đã được ghi nhận:
                            </h6>
                            <small class="text-muted d-block mb-3">
                                <i class="fas fa-shield-alt me-1"></i>
                                *Chúng tôi chỉ hiển thị tên người báo cáo để đảm bảo quyền riêng tư
                            </small>
                            <ul class="reporters-list">
                                @foreach (var reporter in Model.Reporters)
                                {
                                    <li>
                                        <i class="fas fa-user-circle text-primary"></i>
                                        <span>@reporter</span>
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                    <div class="cta-section">
                        <p>
                            <i class="fas fa-hand-point-right me-2"></i>
                            <a href="@Url.Action("Report", "Home", new { query = Model.Query })">
                                Bạn muốn gửi thêm chi tiết về báo cáo này? Nhấn vào đây
                                <i class="fas fa-arrow-right ms-1"></i>
                            </a>
                        </p>
                    </div>
                </div>
            }
            else
            {
                <div class="result-alert alert-success">
                    <h5>
                        <span class="icon">✅</span>
                        <span>Kết quả: @Model.Verdict</span>
                    </h5>

                    <p>
                        <i class="fas fa-check-circle me-2"></i>
                        Số này / Tài khoản / Link <strong>chưa từng bị báo cáo</strong> trên hệ thống của chúng tôi.
                    </p>

                    <p>
                        <i class="fas fa-info-circle me-2"></i>
                        Tuy nhiên, hãy luôn cảnh giác và xác minh kỹ trước khi thực hiện giao dịch.
                    </p>

                    <div class="cta-section success-cta">
                        <p>
                            <i class="fas fa-shield-alt me-2"></i>
                            <a href="@Url.Action("Report", "Home", new { query = Model.Query })">
                                Nếu bạn là nạn nhân, hãy báo cáo ngay để giúp cộng đồng!
                                <i class="fas fa-arrow-right ms-1"></i>
                            </a>
                        </p>
                    </div>
                </div>
            }

            <div class="action-buttons">
                <a href="@Url.Action("Index", "Home")" class="btn btn-outline-primary btn-custom">
                    <i class="fas fa-search"></i>
                    Tra cứu mục khác
                </a>
                <a href="@Url.Action("Report", "Home")" class="btn btn-danger btn-custom">
                    <i class="fas fa-flag"></i>
                    Gửi báo cáo mới
                </a>
            </div>
        </div>
    </div>
</div>