@page
@model WebAdmin.Pages.Accounts.IndexModel
@{
    ViewData["Title"] = "Quản lý tài khoản";
}

<div class="container-fluid p-0">
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-bold text-dark">Quản lý Tài khoản</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/Index">Admin</a></li>
                    <li class="breadcrumb-item active">Người dùng</li>
                </ol>
            </nav>
        </div>
        <div class="col-auto">
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-info py-2 px-3 rounded-4 mb-0 small">
                    <i class="fas fa-info-circle me-1"></i> @TempData["Message"]
                </div>
            }
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Người dùng</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted text-center">Vai trò</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted text-center">Hạn VIP</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">Lượt tra cứu</th>
                        <th class="pe-4 py-3 text-end text-uppercase small fw-bold text-muted">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (Model.PagedData?.Items != null && Model.PagedData.Items.Any())
                    {
                        @foreach (var user in Model.PagedData.Items)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar bg-info bg-opacity-10 text-info rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold">@user.Email</div>
                                            <div class="text-muted x-small" style="font-size: 0.75rem;">UID: #@user.Id</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (user.IsVip)
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning px-3 rounded-pill border border-warning border-opacity-25"><i class="fas fa-crown me-1"></i> VIP</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary px-3 rounded-pill">Thường</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="@(user.IsVip ? "text-success fw-medium" : "text-muted")">
                                        @(user.VipExpiryDate?.ToString("dd/MM/yyyy") ?? "—")
                                    </span>
                                </td>
                                <td>
                                    <div style="max-width: 150px;">
                                        <div class="d-flex justify-content-between mb-1">
                                            <span class="x-small text-muted" style="font-size: 0.7rem;">Sử dụng</span>
                                            <span class="x-small fw-bold" style="font-size: 0.7rem;">@user.SearchCount/15</span>
                                        </div>
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-primary" role="progressbar" style="width: @(user.SearchCount * 100 / 15)%"></div>
                                        </div>
                                    </div>
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="btn-group shadow-sm rounded-3 overflow-hidden">
                                        <a href="#" class="btn btn-sm btn-white border-0 py-2 px-3" title="Edit"><i class="fas fa-edit text-primary"></i></a>
                                        <a href="#" class="btn btn-sm btn-white border-0 py-2 px-3" title="Reset"><i class="fas fa-key text-warning"></i></a>
                                        <button class="btn btn-sm btn-white border-0 py-2 px-3" title="Ban"><i class="fas fa-ban text-danger"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fas fa-folder-open fa-3x mb-3 d-block opacity-25"></i>
                                Không tìm thấy dữ liệu người dùng.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.PagedData != null && Model.PagedData.TotalPages > 1)
        {
            <div class="card-footer bg-white border-0 py-4">
                <nav>
                    <ul class="pagination pagination-sm justify-content-center mb-0">
                        <li class="page-item @(Model.PagedData.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link rounded-circle mx-1 border-0 shadow-sm" asp-route-p="@(Model.PagedData.PageIndex - 1)"><i class="fas fa-chevron-left"></i></a>
                        </li>
                        @for (int i = 1; i <= Model.PagedData.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PagedData.PageIndex ? "active" : "")">
                                <a class="page-link rounded-circle mx-1 border-0 shadow-sm" asp-route-p="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.PagedData.HasNextPage ? "" : "disabled")">
                            <a class="page-link rounded-circle mx-1 border-0 shadow-sm" asp-route-p="@(Model.PagedData.PageIndex + 1)"><i class="fas fa-chevron-right"></i></a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>