@page
@model WebAdmin.Pages.Accounts.IndexModel
@{
    ViewData["Title"] = "Quản lý tài khoản";
}

<div class="container-fluid py-4">
    @* <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary"><i class="fas fa-users-cog me-2"></i>Quản lý tài khoản</h2>
        <button class="btn btn-primary rounded-pill px-4"><i class="fas fa-user-plus me-2"></i>Thêm Admin</button>
    </div> *@

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Người dùng</th>
                        <th>Vai trò</th>
                        <th>Hạn VIP</th>
                        <th>Lượt tra cứu</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@user.Email</div>
                                <div class="small text-muted">ID: @user.Id</div>
                            </td>
                            <td>
                               
                                @if (user.IsVip) { <span class="badge bg-warning text-dark">VIP</span> }
                              
                            </td>
                            <td>@(user.VipExpiryDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td>@user.SearchCount / 15</td>
                            <td class="text-end pe-4">
                                <a href="#" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit"></i></a>
                                <button class="btn btn-sm btn-outline-danger"><i class="fas fa-user-slash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>