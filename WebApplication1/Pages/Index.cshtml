
@page
@model WebAdmin.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard Tổng quan";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="text-primary fw-bold"><i class="fas fa-tachometer-alt me-2"></i> Dashboard Tổng quan</h1>
        <p class="lead text-muted">Chào mừng đến với hệ thống quản trị AntiScam 2026.</p>
    </div>
    <div class="text-end">
        <h4 class="text-warning fw-bold mb-0">Doanh thu tháng này</h4>
        <h2 class="fw-bold">@Model.MonthlyRevenue.ToString("N0")đ</h2>
    </div>
</div>

<div class="row">
    @* Card 1: Doanh thu (Mới thêm) *@
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-0 shadow-sm h-100 bg-warning text-dark">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <i class="fas fa-wallet fa-3x me-3 opacity-50"></i>
                    <div>
                        <h5 class="card-title fw-bold mb-0">TỔNG DOANH THU</h5>
                        <p class="h3 fw-bold">@Model.TotalRevenue.ToString("N0")đ</p>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-dark bg-opacity-10 border-0">
                <span class="small fw-bold">Từ các gói nâng cấp VIP 89k</span>
            </div>
        </div>
    </div>

    @* Card 2: Tổng mục ghi nhận *@
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-0 shadow-sm h-100 bg-primary text-white">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <i class="fas fa-list-alt fa-3x me-3 opacity-50"></i>
                    <div>
                        <h5 class="card-title fw-bold mb-0">MỤC GHI NHẬN</h5>
                        <p class="h3 fw-bold">@Model.TotalEntities</p>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-white bg-opacity-25 border-0">
                <a asp-page="/Reports/Index" class="text-white text-decoration-none small fw-bold">Chi tiết <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </div>

    @* Card 3: Báo cáo chờ duyệt *@
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-0 shadow-sm h-100 @(Model.PendingReports > 0 ? "bg-danger" : "bg-success") text-white">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <i class="fas fa-exclamation-triangle fa-3x me-3 opacity-50"></i>
                    <div>
                        <h5 class="card-title fw-bold mb-0">CHỜ DUYỆT</h5>
                        <p class="h3 fw-bold">@Model.PendingReports</p>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-white bg-opacity-25 border-0">
                <a asp-page="/Reports/Index" class="text-white text-decoration-none small fw-bold">Duyệt ngay <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </div>

    @* Card 4: Khiếu nại chờ xử lý *@
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-0 shadow-sm h-100 @(Model.PendingAppeals > 0 ? "bg-info" : "bg-secondary") text-white">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <i class="fas fa-gavel fa-3x me-3 opacity-50"></i>
                    <div>
                        <h5 class="card-title fw-bold mb-0">KHIẾU NẠI</h5>
                        <p class="h3 fw-bold">@Model.PendingAppeals</p>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-white bg-opacity-25 border-0">
                <a asp-page="/Appeals/Index" class="text-white text-decoration-none small fw-bold">Xử lý <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </div>
    @* Card 5: Quản lý người dùng - Màu Tím (User) *@
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-0 shadow-sm h-100 bg-dark text-white">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <i class="fas fa-users fa-3x me-3 text-info opacity-75"></i>
                    <div>
                        <h5 class="card-title fw-bold mb-0">TỔNG NGƯỜI DÙNG</h5>
                        <p class="h3 fw-bold">@Model.TotalUsers</p>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-white bg-opacity-10 border-0">
                <a asp-page="/Accounts/Index" class="text-info text-decoration-none small fw-bold">
                    Quản lý tài khoản <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>

@* Hoạt động cần chú ý *@
<div class="row mt-2">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-bell text-warning me-2"></i>Thông báo hệ thống</h5>
            </div>
            <div class="card-body">
                @if (Model.PendingReports > 0 || Model.PendingAppeals > 0)
                {
                    <div class="alert alert-danger mb-0 border-0 shadow-sm">
                        <i class="fas fa-shield-alt me-2"></i>
                        <strong>Chú ý:</strong> Đang có @Model.PendingReports báo cáo và @Model.PendingAppeals khiếu nại cần xử lý gấp.
                    </div>
                }
                else
                {
                    <div class="alert alert-success mb-0 border-0 shadow-sm">
                        <i class="fas fa-check-double me-2"></i>
                        Mọi thứ đều ổn! Hệ thống sạch bóng báo cáo tồn đọng.
                    </div>
                }
            </div>
        </div>
    </div>
</div>
