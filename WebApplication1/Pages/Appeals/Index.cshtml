@page
@model WebAdmin.Pages.Appeals.IndexModel
@{
    ViewData["Title"] = "Xử lý khiếu nại";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1"><i class="fas fa-gavel text-primary me-2"></i>Xử lý Khiếu nại</h2>
            <p class="text-muted mb-0">Xem xét và phản hồi các yêu cầu minh oan từ người dùng.</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info border-0 shadow-sm rounded-4 mb-4 py-3 px-4">
            <i class="fas fa-info-circle me-2"></i> @Model.StatusMessage
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white py-3 px-4 border-bottom-0">
            <h6 class="mb-0 fw-bold">Danh sách yêu cầu (@Model.AppealList.Count)</h6>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Query</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">Người Khiếu nại</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted" style="width: 30%;">Lý do</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">Ngày Gửi</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted text-center">Trạng thái</th>
                        <th class="pe-4 py-3 text-end text-uppercase small fw-bold text-muted">Hành động</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var item in Model.PagedData.Items)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-primary">@item.Query</td>
                            <td>
                                <div class="fw-bold">@item.AppellantName</div>
                                <div class="text-muted small">@item.AppellantEmail</div>
                            </td>
                            <td>
                                <div class="text-muted overflow-hidden" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; font-size: 0.85rem;">
                                    @item.Reason
                                </div>
                            </td>
                            <td>@item.SubmittedAt.ToString("dd/MM/yyyy")</td>
                            <td class="text-center">
                                @{
                                    var statusBadge = item.Status switch
                                    {
                                        "Pending" => "bg-warning-subtle text-warning border-warning",
                                        "Accepted" => "bg-success-subtle text-success border-success",
                                        _ => "bg-danger-subtle text-danger border-danger"
                                    };
                                }
                                <span class="badge @statusBadge border rounded-pill px-3">@item.Status</span>
                            </td>
                            <td class="pe-4 text-end">
                                @if (item.Status == "Pending")
                                {
                                    <div class="d-flex justify-content-end gap-2">
                                        <form method="post" asp-page-handler="Accept" asp-route-id="@item.Id">
                                            <button type="submit" class="btn btn-sm btn-success rounded-3"><i class="fas fa-check"></i> Duyệt</button>
                                        </form>
                                        <form method="post" asp-page-handler="Reject" asp-route-id="@item.Id">
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-3"><i class="fas fa-times"></i></button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <span class="badge bg-light text-secondary rounded-pill border">Đã xử lý</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white border-0 py-4">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                <li class="page-item @(Model.PagedData.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link rounded-circle mx-1 border-0 shadow-sm" asp-route-p="@(Model.PagedData.PageIndex - 1)"><i class="fas fa-chevron-left"></i></a>
                </li>
                @for (int i = 1; i <= Model.PagedData.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PagedData.PageIndex ? "active" : "")">
                        <a class="page-link rounded-circle mx-1 border-0 shadow-sm" asp-route-p="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.PagedData.HasNextPage ? "" : "disabled")">
                    <a class="page-link rounded-circle mx-1 border-0 shadow-sm" asp-route-p="@(Model.PagedData.PageIndex + 1)"><i class="fas fa-chevron-right"></i></a>
                </li>
            </ul>
        </div>
    </div>
</div>